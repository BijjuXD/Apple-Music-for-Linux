{
  "appId": "com.archosoftware.amfl",
  "productName": "Music",
  "copyright": "Apple Music Desktop Client for Linux.",
  "electronVersion": "40.7.0+wvcus",
  "electronDownload": {
    "mirror": "https://github.com/castlabs/electron-releases/releases/download/v"
  },
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "assets/**/*",
    "resources/**/*",
    "package.json"
  ],
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "deb",
        "arch": ["x64"]
      },
      {
        "target": "snap",
        "arch": ["x64"]
      },
      {
        "target": "tar.gz",
        "arch": ["x64"]
      }
    ],
    "category": "Audio",
    "icon": "assets/logo.png",
    "executableName": "apple-music",
    "desktop": {
      "Name": "Music",
      "Comment": "Apple Music Desktop Client for Linux",
      "Categories": "Audio;Music;Player;"
    }
  },
  "snap": {
    "confinement": "strict",
    "plugs": ["network", "home", "audio-playback", "x11", "wayland"]
  }
}
