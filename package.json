{
  "name": "apple-music-for-linux",
  "productName": "Music",
  "version": "1.0.0",
  "description": "Apple Music Desktop Client for Linux.",
  "author": "BijjuXD <Brijesh Poojary>",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron . --no-sandbox",
    "watch": "tsc --watch",
    "build": "tsc",
    "start": "electron . --no-sandbox",
    "pack": "pnpm build && electron-builder --linux",
    "pack:appimage": "pnpm build && electron-builder --linux AppImage",
    "pack:deb": "pnpm build && electron-builder --linux deb",
    "pack:snap": "pnpm build && electron-builder --linux snap",
    "pack:tar": "pnpm build && electron-builder --linux tar.gz",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/discord-rpc": "^4.0.10",
    "@types/node": "^20.0.0",
    "electron": "https://github.com/castlabs/electron-releases#v40.7.0+wvcus",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "discord-rpc": "^4.0.1"
  }
}
